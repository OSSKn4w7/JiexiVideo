<?xml version="1.0" encoding="utf-8"?>
<LinearLayout xmlns:android="http://schemas.android.com/apk/res/android"
    android:layout_width="match_parent"
    android:layout_height="wrap_content"
    android:orientation="horizontal"
    android:gravity="center_vertical"
    android:padding="16dp"
    android:background="#0f0f0f">

    <LinearLayout
        android:layout_width="0dp"
        android:layout_height="wrap_content"
        android:layout_weight="1"
        android:orientation="vertical">

        <TextView
            android:id="@+id/qualityNameText"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:textColor="#fff"
            android:textSize="15sp"
            android:textStyle="bold" />

        <TextView
            android:id="@+id/qualityInfoText"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:layout_marginTop="2dp"
            android:textColor="#888"
            android:textSize="12sp" />
    </LinearLayout>

    <LinearLayout
        android:id="@+id/qualityStatusLayout"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:orientation="horizontal"
        android:gravity="center_vertical">

        <TextView
            android:id="@+id/qualityTagText"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:paddingHorizontal="8dp"
            android:paddingVertical="3dp"
            android:textSize="11sp"
            android:textColor="#fff"
            android:background="@drawable/btn_dark_rounded"
            android:visibility="gone" />

        <Button
            android:id="@+id/btnDownload"
            android:layout_width="80dp"
            android:layout_height="36dp"
            android:layout_marginLeft="12dp"
            android:text="下载"
            android:textSize="13sp"
            android:textColor="#fff"
            android:background="@drawable/btn_pink_rounded" />
    </LinearLayout>

</LinearLayout>
