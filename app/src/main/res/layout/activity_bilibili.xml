<?xml version="1.0" encoding="utf-8"?>
<LinearLayout xmlns:android="http://schemas.android.com/apk/res/android"
    android:orientation="vertical"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="@color/background"
    android:padding="18dp">

    <!-- Top bar — glass card -->
    <LinearLayout
        android:id="@+id/loginStatusLayout"
        android:layout_width="match_parent"
        android:layout_height="52dp"
        android:gravity="center_vertical"
        android:orientation="horizontal"
        android:clickable="true"
        android:background="@drawable/topbar_bg"
        android:paddingLeft="6dp"
        android:paddingRight="6dp">


        <ImageView
            android:id="@+id/avatarImage"
            android:layout_width="36dp"
            android:layout_height="36dp"
            android:scaleType="fitCenter"
            android:adjustViewBounds="true"
            android:cropToPadding="false"
            android:src="@drawable/ic_launcher" />

        <LinearLayout
            android:layout_width="0dp"
            android:layout_height="wrap_content"
            android:layout_weight="1"
            android:layout_marginLeft="14dp"
            android:orientation="vertical">

            <TextView
                android:id="@+id/loginStatusText"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="点击登录B站"
                android:textColor="#98989d"
                android:textSize="14sp" />

            <TextView
                android:id="@+id/loginLevelText"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:layout_marginTop="2dp"
                android:textColor="#6e6e73"
                android:textSize="11sp"
                android:visibility="gone" />
        </LinearLayout>

        <Button
            android:id="@+id/btnTheme"
            android:layout_width="52dp"
            android:layout_height="36dp"
            android:text="☀"
            android:textSize="16sp"
            android:textColor="#aaa"
            android:background="@drawable/btn_secondary"
            android:minWidth="0dp" />

        <Button
            android:id="@+id/btnAbout"
            android:layout_width="52dp"
            android:layout_height="36dp"
            android:layout_marginLeft="8dp"
            android:text="ℹ"
            android:textSize="16sp"
            android:textColor="#aaa"
            android:background="@drawable/btn_secondary"
            android:minWidth="0dp" />
    </LinearLayout>

    <!-- URL Input — glass -->
    <EditText
        android:id="@+id/urlInput"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:minHeight="60dp"
        android:layout_marginTop="14dp"
        android:hint="粘贴B站分享链接..."
        android:textColorHint="#50505a"
        android:textColor="#ffffff"
        android:textSize="14sp"
        android:background="@drawable/glass_input"
        android:maxLines="4"
        android:gravity="top"
        android:inputType="textMultiLine" />

    <!-- Parse button — gradient -->
    <Button
        android:id="@+id/btnParse"
        android:layout_width="match_parent"
        android:layout_height="54dp"
        android:layout_marginTop="16dp"
        android:text="解析视频"
        android:textColor="#ffffff"
        android:textSize="16sp"
        android:textStyle="bold"
        android:background="@drawable/btn_primary_gradient" />

    <!-- Download list button -->
    <Button
        android:id="@+id/btnDownloads"
        android:layout_width="match_parent"
        android:layout_height="46dp"
        android:layout_marginTop="10dp"
        android:text="下载列表"
        android:textColor="#98989d"
        android:textSize="14sp"
        android:background="@drawable/btn_secondary" />

    <!-- Loading indicator -->
    <LinearLayout
        android:id="@+id/loadingLayout"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:gravity="center"
        android:orientation="horizontal"
        android:padding="16dp"
        android:visibility="gone">

        <ProgressBar
            android:layout_width="22dp"
            android:layout_height="22dp"
            android:indeterminate="true" />

        <TextView
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:layout_marginLeft="12dp"
            android:text="正在解析..."
            android:textColor="#98989d"
            android:textSize="14sp" />
    </LinearLayout>

    <!-- Error -->
    <TextView
        android:id="@+id/errorText"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:layout_marginTop="12dp"
        android:padding="14dp"
        android:textColor="#ff4d4d"
        android:textSize="13sp"
        android:background="@drawable/glass_card"
        android:visibility="gone" />

    <!-- User info card — glass profile -->
    <LinearLayout
        android:id="@+id/userInfoCard"
        android:layout_width="match_parent"
        android:layout_height="0dp"
        android:layout_weight="1"
        android:layout_marginTop="18dp"
        android:orientation="vertical"
        android:gravity="center"
        android:visibility="gone"
        android:background="@drawable/glass_profile">

        <ImageView
            android:id="@+id/userAvatar"
            android:layout_width="80dp"
            android:layout_height="80dp"
            android:scaleType="centerCrop"
            android:src="@drawable/ic_launcher" />

        <TextView
            android:id="@+id/userNameText"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:layout_marginTop="16dp"
            android:textColor="#ffffff"
            android:textSize="19sp"
            android:textStyle="bold" />

        <TextView
            android:id="@+id/userVipText"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:layout_marginTop="10dp"
            android:textSize="12sp"
            android:textColor="#ffffff"
            android:visibility="gone"
            android:paddingLeft="14dp"
            android:paddingRight="14dp"
            android:paddingTop="5dp"
            android:paddingBottom="5dp"
            android:background="@drawable/vip_badge_bg" />

        <TextView
            android:id="@+id/userMidText"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:layout_marginTop="8dp"
            android:textColor="#98989d"
            android:textSize="12sp" />

        <TextView
            android:id="@+id/userCookieInfo"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:layout_marginTop="12dp"
            android:textColor="#6e6e73"
            android:textSize="11sp" />

        <Button
            android:id="@+id/btnLogout"
            android:layout_width="wrap_content"
            android:layout_height="38dp"
            android:layout_marginTop="18dp"
            android:text="退出登录"
            android:textSize="12sp"
            android:textColor="#8e8e93"
            android:background="@drawable/btn_secondary"
            android:minWidth="0dp"
            android:paddingLeft="24dp"
            android:paddingRight="24dp" />
    </LinearLayout>

    <!-- Hint area -->
    <LinearLayout
        android:id="@+id/hintCard"
        android:layout_width="match_parent"
        android:layout_height="0dp"
        android:layout_weight="1"
        android:gravity="center"
        android:orientation="vertical"
        android:visibility="visible">

        <ImageView
            android:layout_width="90dp"
            android:layout_height="90dp"
            android:scaleType="centerCrop"
            android:src="@drawable/ic_launcher"
            android:alpha="0.08" />

        <TextView
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:layout_marginTop="24dp"
            android:text="粘贴B站视频链接并点击解析"
            android:textColor="#48484d"
            android:textSize="15sp" />

        <TextView
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:layout_marginTop="8dp"
            android:text="登录后解锁更高画质"
            android:textColor="#3a3a40"
            android:textSize="13sp" />
    </LinearLayout>

</LinearLayout>
