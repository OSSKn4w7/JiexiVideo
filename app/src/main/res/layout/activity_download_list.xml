<?xml version="1.0" encoding="utf-8"?>
<LinearLayout xmlns:android="http://schemas.android.com/apk/res/android"
    android:orientation="vertical" android:layout_width="match_parent"
    android:layout_height="match_parent" android:background="@color/background">

    <LinearLayout android:layout_width="match_parent" android:layout_height="48dp"
        android:gravity="center_vertical" android:paddingHorizontal="16dp">
        <Button android:id="@+id/btnBack" android:layout_width="48dp"
            android:layout_height="36dp" android:text="←" android:textSize="18sp"
            android:textColor="@color/btn_secondary_text"
            android:background="#00000000" />
        <TextView android:layout_width="0dp" android:layout_height="wrap_content"
            android:layout_weight="1" android:text="下载列表" android:textColor="@color/text_primary"
            android:textSize="16sp" android:textStyle="bold" android:gravity="center" />
        <Button android:id="@+id/btnClearDone" android:layout_width="wrap_content"
            android:layout_height="36dp" android:text="清除已完成" android:textSize="12sp"
            android:textColor="@color/text_muted" android:background="#00000000" />
    </LinearLayout>

    <LinearLayout android:id="@+id/emptyLayout" android:layout_width="match_parent"
        android:layout_height="0dp" android:layout_weight="1" android:gravity="center"
        android:orientation="vertical" android:visibility="visible">
        <TextView android:layout_width="wrap_content" android:layout_height="wrap_content"
            android:text="暂无下载任务" android:textColor="@color/text_muted"
            android:textSize="16sp" />
        <TextView android:layout_width="wrap_content" android:layout_height="wrap_content"
            android:layout_marginTop="8dp" android:text="解析并下载视频后将在这里显示"
            android:textColor="@color/text_dim" android:textSize="13sp" />
    </LinearLayout>

    <ListView android:id="@+id/downloadListView" android:layout_width="match_parent"
        android:layout_height="0dp" android:layout_weight="1"
        android:divider="@color/divider" android:dividerHeight="1dp"
        android:cacheColorHint="#00000000" android:visibility="gone" />
</LinearLayout>
