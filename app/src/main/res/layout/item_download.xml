<?xml version="1.0" encoding="utf-8"?>
<LinearLayout xmlns:android="http://schemas.android.com/apk/res/android"
    android:layout_width="match_parent" android:layout_height="wrap_content"
    android:orientation="vertical" android:padding="16dp"
    android:layout_marginBottom="8dp" android:background="@drawable/card_bg">

    <TextView android:id="@+id/downloadTitleText" android:layout_width="match_parent"
        android:layout_height="wrap_content" android:textColor="@color/text_primary"
        android:textSize="14sp" android:maxLines="2" android:ellipsize="end" />
    <TextView android:id="@+id/downloadPathText" android:layout_width="match_parent"
        android:layout_height="wrap_content" android:layout_marginTop="3dp"
        android:textColor="@color/text_muted" android:textSize="10sp"
        android:maxLines="2" android:ellipsize="middle" />

    <LinearLayout android:layout_width="match_parent" android:layout_height="wrap_content"
        android:layout_marginTop="8dp" android:orientation="horizontal"
        android:gravity="center_vertical">
        <TextView android:id="@+id/downloadStatusText" android:layout_width="0dp"
            android:layout_height="wrap_content" android:layout_weight="1"
            android:textColor="@color/text_muted" android:textSize="12sp" />
        <ProgressBar android:id="@+id/downloadProgress"
            style="?android:attr/progressBarStyleHorizontal" android:layout_width="0dp"
            android:layout_height="5dp" android:layout_weight="2" android:max="100"
            android:layout_marginLeft="12dp" android:layout_marginRight="12dp"
            android:visibility="gone" />
        <Button android:id="@+id/downloadActionBtn" android:layout_width="64dp"
            android:layout_height="32dp" android:text="暂停" android:textSize="11sp"
            android:textColor="@color/btn_secondary_text"
            android:background="@drawable/btn_secondary" />
    </LinearLayout>
</LinearLayout>
